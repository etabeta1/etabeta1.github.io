{
    "$id": "https://etabeta1.github.io/json_schemas/astralog-rule.schema.json",
	"$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
        "type": {
            "type": "string"
        },
        "rule_id": {
            "type": "string"
        },
        "priority": {
            "enum": ["HIGH", "MIDDLE", "LOW"]
        }
    },
    "required": ["type"],
    "oneOf": [
        {
            "properties": {
                "type": {
                    "const": "simple"
                }
            },
            "$ref": "https://example.com/astralog-rule-simple.schema.json"
        },
        {
            "properties": {
                "type": {
                    "const": "step-difference"
                }
            },
            "$ref": "https://example.com/astralog-rule-step-difference.schema.json"
        },
        {
            "properties": {
                "type": {
                    "const": "stateful"
                }
            },
            "$ref": "https://example.com/astralog-rule-stateful.schema.json"
        },
        {
            "properties": {
                "type": {
                    "const": "correlation"
                }
            },
            "$ref": "https://example.com/astralog-rule-correlation.schema.json"
        }
    ]
}