{
    "$id": "https://etabeta1.github.io/json_schemas/astralog-measurement.schema.json",
	"$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
        "timestamp": {
            "type": "string"
        },
        "sensor_id": {
            "type": "string"
        },
        "value": {
            "type": "number"
        },
        "priority": {
            "enum": ["HIGH", "MIDDLE", "LOW"]
        }
    },
    "required": ["timestamp", "sensor_id", "value", "priority"]
}