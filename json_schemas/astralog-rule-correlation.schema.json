{
    "$id": "https://etabeta1.github.io/json_schemas/astralog-rule-correlation.schema.json",
	"$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
        "logic": {
            "enum": ["AND", "OR"]
        },
        "conditions": {
            "type": "array",
            "items": {
                "type": "string"
            }
        }
    },
    "required": ["logic", "conditions"]
}